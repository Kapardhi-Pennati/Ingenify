# Google Service Account email (from your GCP credentials JSON)
GOOGLE_CLIENT_EMAIL=your-service-account@your-project-id.iam.gserviceaccount.com

# IMPORTANT: Keep this value in double quotes and use escaped newlines (\n)
# Example format below:
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASC...\n...rest-of-key...\n-----END PRIVATE KEY-----\n"

# Spreadsheet ID from the Google Sheet URL
# Example URL: https://docs.google.com/spreadsheets/d/1AbCdEfGhIjKlMnOpQrStUvWxYz1234567890/edit
# Use only the ID segment between /d/ and /edit
GOOGLE_SHEET_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz1234567890
